{
  "name": "@urban/gitai",
  "version": "0.0.0",
  "bin": {
    "gitai": "./src/cli.ts"
  },
  "files": [
    "./package.json",
    "./src/**/*.ts"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/cli.ts"
  },
  "scripts": {
    "cli": "bun run ./src/cli.ts",
    "check": "bun run lint && bun run typecheck && bun run test",
    "lint": "oxfmt && oxlint --fix",
    "prepare": "effect-tsgo patch",
    "setup:zed-effect-tsgo": "bash scripts/setup-zed-effect-tsgo.sh",
    "test": "vitest run",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.65",
    "effect": "4.0.0-beta.65"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@effect/language-service": "0.85.1",
    "@effect/tsgo": "0.6.0",
    "@effect/vitest": "4.0.0-beta.65",
    "@types/bun": "1.3.13",
    "@types/node": "25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260511.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "typescript": "latest",
    "vitest": "4.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxfmt",
      "oxlint --fix"
    ],
    "*.{css,html,json,jsonc,md,mdx,yml,yaml}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">= 24.12.0"
  },
  "packageManager": "bun@1.3.5"
}
